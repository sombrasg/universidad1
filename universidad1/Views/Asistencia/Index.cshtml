@model List<universidad1.Models.Asistencia>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Control de Asistencia General</h2>
        <a asp-action="Create" class="btn btn-danger">Pasar Lista</a>
    </div>

    <table class="table table-hover shadow-sm bg-white">
        <thead class="table-dark">
            <tr>
                <th>Fecha</th>
                <th>Alumno</th>
                <th>Materia (Grupo)</th>
                <th>Estado</th>
                <th>Observaciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                    <td><strong>@item.NombreAlumno</strong></td>
                    <td>@item.NombreMateria (@item.ClaveGrupo)</td>
                    <td>
                        <span class="badge @(item.Estado == "Presente" ? "bg-success" : (item.Estado == "Ausente" ? "bg-danger" : "bg-warning"))">
                            @item.Estado
                        </span>
                    </td>
                    <td><small class="text-muted">@item.Observaciones</small></td>
                </tr>
            }
        </tbody>
    </table>
</div>