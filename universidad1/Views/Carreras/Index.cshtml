@model List<universidad1.Models.Carrera>

@{
    ViewData["Title"] = "Oferta Académica";
}

<div class="container mt-4">
    <h2>Oferta Académica (Carreras)</h2>
    <hr />

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Clave</th>
                <th>Nombre de la Carrera</th>
                <th>Duración (Semestres)</th>
                <th>Estatus</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr><td colspan="4" class="text-center">No hay carreras registradas.</td></tr>
            }
            else
            {
                @foreach (var carrera in Model)
                {
                    <tr>
                        <td><strong>@carrera.ClaveCarrera</strong></td>
                        <td>@carrera.NombreCarrera</td>
                        <td>@carrera.DuracionSemestres</td>
                        <td>
                            @if (carrera.EstatusActivo)
                            {
                                <span class="badge bg-success">Activa</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactiva</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>