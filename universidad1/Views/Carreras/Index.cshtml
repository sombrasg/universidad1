@model List<universidad1.Models.Carrera>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-mortarboard"></i> Gestión de Carreras</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Registrar Nueva Carrera
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover shadow-sm align-middle bg-white">
            <thead class="table-dark">
                <tr>
                    <th>Clave</th>
                    <th>Nombre de la Carrera</th>
                    <th class="text-center">Duración</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary">@c.ClaveCarrera</span></td>
                        <td><strong>@c.NombreCarrera</strong></td>
                        <td class="text-center">@c.DuracionSemestres Semestres</td>
                        <td class="text-center">
                            @if (c.EstatusActivo)
                            {
                                <span class="badge rounded-pill bg-success">Activa</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-danger">Inactiva</span>
                            }
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>