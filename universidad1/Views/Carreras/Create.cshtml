@model universidad1.Models.Carrera

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Registrar Nueva Oferta Académica</h4>
        </div>
        <div class="card-body bg-light">
            <form asp-action="Create" method="post">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Clave de Carrera</label>
                        <input asp-for="ClaveCarrera" class="form-control" placeholder="Ej: ING-SIS" required />
                    </div>
                    <div class="col-md-8 mb-3">
                        <label class="form-label fw-bold">Nombre Completo</label>
                        <input asp-for="NombreCarrera" class="form-control" placeholder="Ingeniería en Sistemas..." required />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Duración (Semestres)</label>
                        <input asp-for="DuracionSemestres" type="number" min="1" max="15" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3 d-flex align-items-center mt-4">
                        <div class="form-check form-switch">
                            <input asp-for="EstatusActivo" class="form-check-input" type="checkbox" id="flexSwitchCheckDefault" checked>
                            <label class="form-check-label fw-bold" for="flexSwitchCheckDefault">Carrera Activa</label>
                        </div>
                    </div>
                </div>

                <div class="text-end mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary px-5">Guardar Carrera</button>
                </div>
            </form>
        </div>
    </div>
</div>