@model universidad1.Models.Profesor

<div class="container mt-4">
    <h2>Registrar Profesor</h2>
    <hr />
    <form asp-action="Create" method="post" class="shadow-sm p-4 border rounded">
        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Número de Empleado</label>
                <input asp-for="NumeroEmpleado" class="form-control" required placeholder="P-001" />
            </div>
            <div class="col-md-8 mb-3">
                <label class="form-label fw-bold">Departamento Asignado</label>
                <select asp-for="DepartamentoId" class="form-select" asp-items="ViewBag.Departamentos" required>
                    <option value="">-- Seleccione Departamento --</option>
                </select>
            </div>
        </div>
        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Nombre</label>
                <input asp-for="Nombre" class="form-control" required />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Apellido Paterno</label>
                <input asp-for="ApellidoPaterno" class="form-control" required />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Apellido Materno</label>
                <input asp-for="ApellidoMaterno" class="form-control" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Teléfono</label>
                <input asp-for="Telefono" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Correo Electrónico</label>
                <input asp-for="Correo" type="email" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Especialidad</label>
                <input asp-for="Especialidad" class="form-control" />
            </div>
        </div>
        <div class="mt-3 text-end">
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            <button type="submit" class="btn btn-success">Guardar Profesor</button>
        </div>
    </form>
</div>