@model List<universidad1.Models.Pago>

@{
    ViewData["Title"] = "Control de Pagos";
}

<div class="container mt-4">
    <h2>Historial de Pagos y Colegiaturas</h2>
    <hr />

    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Folio Reg.</th>
                <th class="text-info">Alumno (JOIN)</th>
                <th>Periodo (JOIN)</th>
                <th>Concepto</th>
                <th class="text-success">Monto</th>
                <th>Fecha de Pago</th>
                <th>Método</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr><td colspan="7" class="text-center">No hay pagos registrados.</td></tr>
            }
            else
            {
                @foreach (var pago in Model)
                {
                    <tr>
                        <td>@pago.Id</td>
                        <td><strong>@pago.NombreAlumno</strong></td>
                        <td><span class="badge bg-secondary">@pago.ClavePeriodo</span></td>
                        <td>@pago.Concepto</td>
                        <td class="text-success fw-bold">$@pago.Monto.ToString("0.00")</td>
                        <td>@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                        <td>@pago.MetodoPago</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>