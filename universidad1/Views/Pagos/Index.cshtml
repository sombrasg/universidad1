@model List<universidad1.Models.Pago>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Historial Financiero</h2>
        <a asp-action="Create" class="btn btn-primary">Registrar Nuevo Pago</a>
    </div>

    <table class="table table-hover shadow-sm bg-white">
        <thead class="table-dark">
            <tr>
                <th>Fecha</th>
                <th>Matrícula</th>
                <th>Alumno</th>
                <th>Concepto</th>
                <th>Monto</th>
                <th>Método</th>
                <th>Referencia</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.FechaPago.ToString("dd/MM/yyyy HH:mm")</td>
                    <td><span class="badge bg-light text-dark">@p.Matricula</span></td>
                    <td>@p.NombreAlumno</td>
                    <td>@p.Concepto</td>
                    <td class="fw-bold text-success">$@p.Monto.ToString("N2")</td>
                    <td>@p.MetodoPago</td>
                    <td><small class="text-muted">@p.ReferenciaBancaria</small></td>
                </tr>
            }
        </tbody>
    </table>
</div>