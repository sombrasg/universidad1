@model universidad1.Models.Pago

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0"><i class="bi bi-cash-coin"></i> Registro de Pago con Descuento Académico</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Alumno</label>
                        <select asp-for="AlumnoId" id="selAlumno" asp-items="ViewBag.Alumnos" class="form-select border-success" required>
                            <option value="">-- Seleccionar Alumno --</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Periodo</label>
                        <select asp-for="PeriodoId" id="selPeriodo" asp-items="ViewBag.Periodos" class="form-select border-success" required></select>
                    </div>
                </div>

                <div class="row bg-light p-3 rounded border mb-3">
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Concepto</label>
                        <select asp-for="Concepto" id="cboConcepto" class="form-select" required>
                            <option value="" data-precio="0">-- Seleccione --</option>
                            <option value="Inscripción Semestral" data-precio="2500">Inscripción Semestral</option>
                            <option value="Mensualidad" data-precio="1200">Mensualidad</option>
                            <option value="Examen Extraordinario" data-precio="450">Examen Extraordinario</option>
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Costo Base ($)</label>
                        <input id="txtCostoBase" type="text" class="form-control" readonly />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Beca Aplicada (%)</label>
                        <input id="txtBeca" type="text" class="form-control text-primary fw-bold" readonly value="0" />
                    </div>
                </div>

                <div class="row align-items-center">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Método y Referencia</label>
                        <div class="input-group">
                            <select asp-for="MetodoPago" class="form-select" required>
                                <option>Transferencia</option>
                                <option>Efectivo</option>
                                <option>Tarjeta</option>
                            </select>
                            <input asp-for="ReferenciaBancaria" class="form-control" placeholder="Folio/Ref" required />
                        </div>
                    </div>
                    <div class="col-md-6 mb-3 text-center">
                        <label class="form-label fw-bold text-danger">TOTAL A COBRAR</label>
                        <input asp-for="Monto" id="txtTotal" type="number" step="0.01" class="form-control form-control-lg text-center fw-bold border-danger" required readonly />
                    </div>
                </div>

                <div class="text-end mt-3">
                    <button type="submit" class="btn btn-success btn-lg px-5">Finalizar Transacción</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const selAlumno = document.getElementById('selAlumno');
        const selPeriodo = document.getElementById('selPeriodo');
        const cboConcepto = document.getElementById('cboConcepto');
        const txtCostoBase = document.getElementById('txtCostoBase');
        const txtBeca = document.getElementById('txtBeca');
        const txtTotal = document.getElementById('txtTotal');

        function calcularPago() {
            const alumnoId = selAlumno.value;
            const periodoId = selPeriodo.value;
            const conceptoSelect = cboConcepto.options[cboConcepto.selectedIndex];
            const precioBase = parseFloat(conceptoSelect.getAttribute('data-precio')) || 0;

            if (!alumnoId || !periodoId) return;

            // 1. Buscamos si tiene beca mediante AJAX
            fetch(`/Pagos/GetDescuentoAlumno?alumnoId=${alumnoId}&periodoId=${periodoId}`)
                .then(res => res.json())
                .then(data => {
                    const porcBeca = data.porcentaje;
                    txtCostoBase.value = precioBase.toFixed(2);
                    txtBeca.value = porcBeca + "%";

                    // 2. Aplicamos la fórmula: Total = Base * (1 - Beca/100)
                    const descuento = precioBase * (porcBeca / 100);
                    const totalFinal = precioBase - descuento;

                    txtTotal.value = totalFinal.toFixed(2);
                });
        }

        selAlumno.addEventListener('change', calcularPago);
        cboConcepto.addEventListener('change', calcularPago);
    </script>
}