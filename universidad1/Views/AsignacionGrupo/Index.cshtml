

@{
    ViewData["Title"] = "Listas de Clase";
}

<div class="container mt-4">
    <div class="alert alert-info shadow-sm border-0 d-flex align-items-center">
        <div class="flex-grow-1">
            <h2 class="mb-0">Asignación de Alumnos a Grupos</h2>
            <p class="mb-0">Consulta qué alumnos están inscritos en cada materia.</p>
        </div>
        <div class="display-6">
            <i class="bi bi-people-fill"></i>
        </div>
    </div>
    <hr />

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Alumno</th>
                    <th>Clave de Grupo</th>
                    <th>Materia Asignada</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || Model.Count == 0)
                {
                    <tr><td colspan="4" class="text-center">No hay alumnos asignados a grupos todavía.</td></tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td><i class="bi bi-person-badge me-2"></i><strong>@item.NombreAlumno</strong></td>
                            <td><span class="badge bg-primary">@item.ClaveGrupo</span></td>
                            <td>@item.NombreMateria</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>