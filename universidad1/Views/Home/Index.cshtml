@model universidad1.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard - EASYBARD";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm p-4 text-white" style="background: linear-gradient(to right, #0a2558, #1976d2); border-radius: 15px;">
            <h1 class="display-5 fw-bold">Bienvenido a EASYBARD</h1>
            <p class="lead mb-0">Datos reales obtenidos del sistema de gestión académica.</p>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm h-100 p-3 border-start border-primary border-5" style="border-radius: 10px;">
            <div class="d-flex align-items-center">
                <i class="bi bi-people-fill fs-2 text-primary me-3"></i>
                <div>
                    <h6 class="text-muted mb-0 small text-uppercase">Total Alumnos</h6>
                    <h4 class="fw-bold mb-0">@Model.TotalAlumnos</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm h-100 p-3 border-start border-success border-5" style="border-radius: 10px;">
            <div class="d-flex align-items-center">
                <i class="bi bi-cash-coin fs-2 text-success me-3"></i>
                <div>
                    <h6 class="text-muted mb-0 small text-uppercase">Caja Total</h6>
                    <h4 class="fw-bold mb-0">@Model.CajaTotal.ToString("C")</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm h-100 p-3 border-start border-warning border-5" style="border-radius: 10px;">
            <div class="d-flex align-items-center">
                <i class="bi bi-mortarboard-fill fs-2 text-warning me-3"></i>
                <div>
                    <h6 class="text-muted mb-0 small text-uppercase">Carreras</h6>
                    <h4 class="fw-bold mb-0">@Model.TotalCarreras</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm h-100 p-3 border-start border-danger border-5" style="border-radius: 10px;">
            <div class="d-flex align-items-center">
                <i class="bi bi-building fs-2 text-danger me-3"></i>
                <div>
                    <h6 class="text-muted mb-0 small text-uppercase">Grupos Activos</h6>
                    <h4 class="fw-bold mb-0">@Model.GruposActivos</h4>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8 mb-4">
        <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 15px;">
            <h5 class="fw-bold mb-4 text-dark">
                <i class="bi bi-lightning-charge text-primary me-2"></i>Inscripciones Recientes
            </h5>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Alumno</th>
                            <th>Carrera</th>
                            <th class="text-center">Fecha</th>
                            <th class="text-center">Estatus</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Recientes)
                        {
                            <tr>
                                <td><strong>@item.Alumno</strong></td>
                                <td>@item.Carrera</td>
                                <td class="text-center text-muted">@item.Fecha</td>
                                <td class="text-center">
                                    <span class="badge bg-success-subtle text-success border border-success">Completado</span>
                                </td>
                            </tr>
                        }
                        @if (Model.Recientes.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-3">No hay inscripciones recientes.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 15px;">
            <h5 class="fw-bold mb-4 text-dark">
                <i class="bi bi-megaphone text-primary me-2"></i>Avisos EASYBARD
            </h5>
            
            <div class="alert alert-info border-0 shadow-sm py-2 mb-3">
                <h6 class="fw-bold mb-1 small text-primary">Cierre de Actas</h6>
                <p class="mb-0 small text-dark">Faltan 3 días para el cierre del primer parcial.</p>
            </div>

            <div class="alert alert-light border-0 shadow-sm py-2 mb-3 border-start border-success border-4">
                <h6 class="fw-bold mb-1 small text-success">Mantenimiento</h6>
                <p class="mb-0 small text-dark">Laboratorio B en mantenimiento este sábado.</p>
            </div>
            
            <div class="alert alert-light border-0 shadow-sm py-2 mb-0 border-start border-warning border-4">
                <h6 class="fw-bold mb-1 small text-warning">Reinscripciones</h6>
                <p class="mb-0 small text-dark">Periodo abierto para alumnos regulares.</p>
            </div>
        </div>
    </div>
</div>