@model universidad1.Models.Periodo

<div class="container mt-4">
    <h2>Editar Periodo: @Model.ClavePeriodo</h2>
    <hr />
    <form asp-action="Edit" method="post" class="shadow-sm p-4 border rounded border-warning border-top border-4 bg-light">
        <input type="hidden" asp-for="Id" />
        
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Clave del Periodo</label>
                <input asp-for="ClavePeriodo" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Cambiar Estatus</label>
                <select asp-for="Activo" class="form-select" required>
                    <option value="true">Activo (En curso)</option>
                    <option value="false">Inactivo (Cerrado)</option>
                </select>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Fecha de Inicio</label>
                <input asp-for="FechaInicio" type="date" asp-format="{0:yyyy-MM-dd}" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Fecha de Fin</label>
                <input asp-for="FechaFin" type="date" asp-format="{0:yyyy-MM-dd}" class="form-control" required />
            </div>
        </div>
        <div class="mt-3 text-end">
            <a asp-action="Index" class="btn btn-secondary me-2">Cancelar</a>
            <button type="submit" class="btn btn-warning"><i class="bi bi-pencil-square"></i> Actualizar Periodo</button>
        </div>
    </form>
</div>