@model List<universidad1.Models.Periodo>

@{
    ViewData["Title"] = "Periodos Académicos";
}

<div class="container mt-4">
    <h2>Ciclos y Periodos Académicos</h2>
    <hr />

    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th class="text-info">Clave del Periodo</th>
                <th>Fecha de Inicio</th>
                <th>Fecha de Fin</th>
                <th>Estatus</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || Model.Count == 0)
            {
                <tr><td colspan="5" class="text-center">No hay periodos registrados.</td></tr>
            }
            else
            {
                @foreach (var periodo in Model)
                {
                    <tr>
                        <td>@periodo.Id</td>
                        <td><strong>@periodo.ClavePeriodo</strong></td>
                        <td>@periodo.FechaInicio.ToString("dd/MMM/yyyy")</td>
                        <td>@periodo.FechaFin.ToString("dd/MMM/yyyy")</td>
                        <td>
                            @* Lógica de negocio inteligente para evaluar el estatus *@
                            @if (periodo.EstatusActivo)
                            {
                                <span class="badge bg-success">En Curso / Activo</span>
                            }
                            else if (periodo.FechaInicio > DateTime.Now)
                            {
                                <span class="badge bg-info text-dark">Próximo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Finalizado</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>