@model List<universidad1.Models.BecaAcademica>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-award"></i> Registro de Becas Académicas</h2>
        <a asp-action="Create" class="btn btn-primary">Asignar Nueva Beca</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle shadow-sm bg-white">
            <thead class="table-dark">
                <tr>
                    <th>Alumno</th>
                    <th>Tipo de Beca</th>
                    <th>Descuento</th>
                    <th>Periodo</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td><strong>@b.NombreAlumno</strong></td>
                        <td>@b.NombreBeca</td>
                        <td><span class="badge bg-success">@b.PorcentajeDescuento.ToString("0")%</span></td>
                        <td>@b.ClavePeriodo</td>
                        <td>
                            @if (b.EstatusActiva)
                            {
                                <span class="text-success"><i class="bi bi-check-circle-fill"></i> Vigente</span>
                            }
                            else
                            {

                                <span class="text-danger"><i class="bi bi-x-circle-fill"></i> Suspendida</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>