<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EASYBARD Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div id="wrapper">
        <div id="sidebar-wrapper">
            <div class="sidebar-heading text-center">
                <div class="logo-container mb-3">
                    <img src="~/images/easybard.jpeg" alt="Logo Easybard" />
                </div>
                <span class="fs-4 fw-bold text-white tracking-tight">EASYBARD</span>
                <p class="sidebar-subtitle text-uppercase">Sistemas de Gestión</p>
            </div>
            
            <div class="list-group list-group-flush mt-2">
                <p class="sidebar-category">Resumen</p>
                <a asp-controller="Home" asp-action="Index" class="list-group-item">
                    <i class="bi bi-grid-1x2-fill"></i> Panel de Control
                </a>
                
                <p class="sidebar-category">Gestión Escolar</p>
                <a asp-controller="Alumnos" asp-action="Index" class="list-group-item"><i class="bi bi-people-fill"></i> Alumnos</a>
                <a asp-controller="Inscripciones" asp-action="Index" class="list-group-item"><i class="bi bi-person-plus-fill"></i> Inscripciones</a>
                <a asp-controller="AsignacionGrupo" asp-action="Index" class="list-group-item"><i class="bi bi-clipboard2-check-fill"></i> Listas de Clase</a>
                <a asp-controller="Asistencia" asp-action="Index" class="list-group-item"><i class="bi bi-calendar-check-fill"></i> Registro Asistencia</a>
                <a asp-controller="Calificaciones" asp-action="Index" class="list-group-item"><i class="bi bi-journal-check"></i> Calificaciones</a>
                <a asp-controller="Busqueda" asp-action="Index" class="list-group-item">
                    <i class="bi bi-person-bounding-box"></i> Localizador Alumnos
                </a>

                <p class="sidebar-category">Administración Finanzas</p>
                <a asp-controller="Pagos" asp-action="Index" class="list-group-item"><i class="bi bi-cash-stack"></i> Caja y Cobranza</a>
                <a asp-controller="Becas" asp-action="Index" class="list-group-item"><i class="bi bi-award-fill"></i> Becas Académicas</a>

                <p class="sidebar-category">Estructura Académica</p>
                <a asp-controller="Profesores" asp-action="Index" class="list-group-item"><i class="bi bi-person-workspace"></i> Planta Docente</a>
                <a asp-controller="Materias" asp-action="Index" class="list-group-item"><i class="bi bi-book-half"></i> Materias</a>
                <a asp-controller="Grupos" asp-action="Index" class="list-group-item"><i class="bi bi-collection-fill"></i> Grupos</a>
                <a asp-controller="Carreras" asp-action="Index" class="list-group-item"><i class="bi bi-mortarboard-fill"></i> Carreras</a>
                <a asp-controller="Aulas" asp-action="Index" class="list-group-item"><i class="bi bi-door-open-fill"></i> Aulas</a>
                <a asp-controller="Horarios" asp-action="Index" class="list-group-item"><i class="bi bi-clock-fill"></i> Horarios</a>
            </div>
        </div>

        <div id="page-content-wrapper">
            <nav class="navbar navbar-expand-lg navbar-custom px-4 py-2 border-0 shadow-sm">
                <div class="container-fluid p-0">
                    <span class="navbar-brand fw-bold text-primary" style="font-size: 1.1rem;">
                        <i class="bi bi-chevron-right me-1 small"></i> @ViewData["Title"]
                    </span>
                    <div class="ms-auto d-flex align-items-center">
                        <div class="dropdown">
                            <button class="btn btn-light dropdown-toggle rounded-pill shadow-sm py-1 px-3 border" type="button" data-bs-toggle="dropdown">
                                <span class="me-2 d-none d-md-inline small fw-bold text-dark">Admin Easybard</span>
                                <i class="bi bi-person-circle text-primary fs-5"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-gear me-2"></i> Ajustes Perfil</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger py-2" href="#"><i class="bi bi-box-arrow-right me-2"></i> Salir</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <div class="container-fluid p-0">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>