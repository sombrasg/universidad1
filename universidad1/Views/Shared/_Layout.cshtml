<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Easyvard Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div id="wrapper">
        <div id="sidebar-wrapper">
            <div class="sidebar-heading text-center">
                <div class="logo-container mb-3">
                    <img src="" C:\Users\arcos\Downloads\easybard.jpeg"" alt="Logo EasyBard" />
                </div>
                <span class="fs-4 fw-bold text-white tracking-tight">EASYVARD</span>
                <p class="small mb-0 opacity-50 text-white text-uppercase" style="font-size: 0.6rem; letter-spacing: 2px;">Sistema de Gestión</p>
            </div>
            
            <div class="list-group list-group-flush mt-3">
                <p class="text-uppercase text-muted small fw-bold px-4 mb-1" style="font-size: 0.65rem;">Principal</p>
                <a asp-controller="Home" asp-action="Index" class="list-group-item"><i class="bi bi-speedometer2"></i> Dashboard</a>
                
                <p class="text-uppercase text-muted small fw-bold px-4 mt-3 mb-1" style="font-size: 0.65rem;">Gestión Escolar</p>
                <a asp-controller="Alumnos" asp-action="Index" class="list-group-item"><i class="bi bi-people"></i> Alumnos</a>
                <a asp-controller="Inscripciones" asp-action="Index" class="list-group-item"><i class="bi bi-journal-plus"></i> Inscripciones</a>
                <a asp-controller="AsignacionGrupo" asp-action="Index" class="list-group-item"><i class="bi bi-person-badge"></i> Listas de Clase</a>
                <a asp-controller="Asistencia" asp-action="Index" class="list-group-item"><i class="bi bi-calendar-check"></i> Asistencia</a>
                <a asp-controller="Calificaciones" asp-action="Index" class="list-group-item"><i class="bi bi-clipboard-data"></i> Calificaciones</a>

                <p class="text-uppercase text-muted small fw-bold px-4 mt-3 mb-1" style="font-size: 0.65rem;">Finanzas</p>
                <a asp-controller="Pagos" asp-action="Index" class="list-group-item"><i class="bi bi-cash-stack"></i> Caja y Cobranza</a>
                <a asp-controller="Becas" asp-action="Index" class="list-group-item"><i class="bi bi-award"></i> Becas Académicas</a>

                <p class="text-uppercase text-muted small fw-bold px-4 mt-3 mb-1" style="font-size: 0.65rem;">Infraestructura</p>
                <a asp-controller="Profesores" asp-action="Index" class="list-group-item"><i class="bi bi-person-workspace"></i> Planta Docente</a>
                <a asp-controller="Materias" asp-action="Index" class="list-group-item"><i class="bi bi-book"></i> Materias</a>
                <a asp-controller="Grupos" asp-action="Index" class="list-group-item"><i class="bi bi-collection"></i> Grupos</a>
                <a asp-controller="Carreras" asp-action="Index" class="list-group-item"><i class="bi bi-briefcase"></i> Carreras</a>
                <a asp-controller="Aulas" asp-action="Index" class="list-group-item"><i class="bi bi-door-open"></i> Aulas</a>
                <a asp-controller="Horarios" asp-action="Index" class="list-group-item"><i class="bi bi-clock"></i> Horarios</a>
            </div>
        </div>

        <div id="page-content-wrapper">
            <nav class="navbar navbar-expand-lg navbar-custom px-4 py-2 border-0">
                <div class="container-fluid p-0">
                    <span class="navbar-brand fw-bold text-primary" style="font-size: 1.1rem;">
                        @ViewData["Title"]
                    </span>
                    <div class="ms-auto d-flex align-items-center">
                        <div class="dropdown">
                            <button class="btn btn-light dropdown-toggle rounded-pill shadow-sm py-1 px-3" type="button" data-bs-toggle="dropdown">
                                <span class="me-2 d-none d-md-inline small fw-bold">Admin Easyvard</span>
                                <i class="bi bi-person-circle text-primary fs-5"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-gear me-2"></i> Configuración</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger py-2" href="#"><i class="bi bi-box-arrow-right me-2"></i> Salir</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <div class="container-fluid p-0">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>