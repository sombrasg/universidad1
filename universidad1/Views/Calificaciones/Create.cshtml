@model universidad1.Models.Calificacion

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Registrar Calificaciones</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Alumno</label>
                        <select asp-for="AlumnoId" asp-items="ViewBag.Alumnos" class="form-select" required></select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Grupo / Materia</label>
                        <select asp-for="GrupoId" asp-items="ViewBag.Grupos" class="form-select" required></select>
                    </div>
                </div>

                <div class="row bg-light p-3 rounded mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Primer Parcial</label>
                        <input asp-for="Parcial1" id="p1" type="number" step="0.1" min="0" max="10" class="form-control nota" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Segundo Parcial</label>
                        <input asp-for="Parcial2" id="p2" type="number" step="0.1" min="0" max="10" class="form-control nota" required />
                    </div>
                    <div class="col-md-4 text-center">
                        <label class="form-label fw-bold">Promedio Sugerido</label>
                        <h3 id="lblPromedio" class="text-primary">0.0</h3>
                    </div>
                </div>

                <div class="text-end">
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
                    <button type="submit" class="btn btn-primary px-4">Guardar Acta</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.nota').forEach(input => {
            input.addEventListener('input', () => {
                let n1 = parseFloat(document.getElementById('p1').value) || 0;
                let n2 = parseFloat(document.getElementById('p2').value) || 0;
                let prom = (n1 + n2) / 2;
                document.getElementById('lblPromedio').innerText = prom.toFixed(2);
                document.getElementById('lblPromedio').className = prom >= 6 ? "text-success" : "text-danger";
            });
        });
    </script>
}