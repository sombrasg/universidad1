@model List<universidad1.Models.Materia>

@{
    ViewData["Title"] = "Mapa Curricular";
}

<div class="container mt-4">
    <h2>Catálogo de Materias</h2>
    <hr />

    <div class="mb-3 mt-3">
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Agregar Nueva Materia
        </a>
    </div>
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Clave</th>
                <th>Nombre de la Materia</th>
                <th>Créditos</th>
                <th>Horas (T/P)</th>
                <th>Semestre</th>
                <th class="text-info">Carrera</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr><td colspan="6" class="text-center">No hay materias registradas.</td></tr>
            }
            else
            {
                @foreach (var materia in Model)
                {
                    <tr>
                        <td><strong>@materia.Clave</strong></td>
                        <td>@materia.NombreMateria</td>
                        <td>@materia.Creditos</td>
                        <td>@materia.HorasTeoricas / @materia.HorasPracticas</td>
                        <td>@materia.SemestreSugerido</td>
                        <td>@materia.NombreCarrera</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>