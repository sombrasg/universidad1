@model List<universidad1.Models.Grupo>

@{
    ViewData["Title"] = "Gestión de Grupos";
}

<div class="container mt-4">
    <h2>Control de Grupos y Clases</h2>
    <hr />

    <div class="mb-3 mt-3 text-end">
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-square"></i> Abrir Nuevo Grupo
        </a>
    </div>

    <table class="table table-striped table-hover shadow-sm align-middle">
        <thead class="table-dark">
            <tr>
                <th>Grupo</th>
                <th>Periodo</th>
                <th class="text-primary">Materia</th>
                <th class="text-info">Profesor</th>
                <th class="text-warning">Aula</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr><td colspan="6" class="text-center">No hay grupos registrados.</td></tr>
            }
            else
            {
                @foreach (var grupo in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary">@grupo.ClaveGrupo</span></td>
                        <td>@grupo.ClavePeriodo</td>
                        <td><strong>@grupo.NombreMateria</strong></td>
                        <td>@grupo.NombreProfesor</td>
                        <td>@grupo.CodigoAula</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@grupo.Id" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>