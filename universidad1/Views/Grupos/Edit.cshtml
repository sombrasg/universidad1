@model universidad1.Models.Grupo

<div class="container mt-4">
    <h2>Editar Grupo: @Model.ClaveGrupo</h2>
    <hr />
    <form asp-action="Edit" method="post" class="shadow-sm p-4 border rounded border-warning border-top border-4 bg-light">
        <input type="hidden" asp-for="Id" />
        
        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Clave del Grupo</label>
                <input asp-for="ClaveGrupo" class="form-control" required />
            </div>
            <div class="col-md-8 mb-3">
                <label class="form-label fw-bold">Cambiar Periodo</label>
                <select asp-for="PeriodoId" class="form-select" asp-items="ViewBag.Periodos" required></select>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 mb-3">
                <label class="form-label fw-bold">Cambiar Materia</label>
                <select asp-for="MateriaId" class="form-select" asp-items="ViewBag.Materias" required></select>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Cambiar Profesor</label>
                <select asp-for="ProfesorId" class="form-select" asp-items="ViewBag.Profesores" required></select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Cambiar Aula</label>
                <select asp-for="AulaId" class="form-select" asp-items="ViewBag.Aulas" required></select>
            </div>
        </div>
        <div class="mt-3 text-end">
            <a asp-action="Index" class="btn btn-secondary me-2">Cancelar</a>
            <button type="submit" class="btn btn-warning"><i class="bi bi-pencil-square"></i> Actualizar Grupo</button>
        </div>
    </form>
</div>