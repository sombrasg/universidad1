@model universidad1.Models.Inscripcion

<div class="container mt-4">
    <h2>Inscribir Alumno a Carrera</h2>
    <hr />
    <form asp-action="Create" method="post" class="shadow-sm p-4 border rounded bg-light">
        <div class="row">
            <div class="col-md-12 mb-3">
                <label class="form-label fw-bold">Seleccionar Alumno</label>
                <select asp-for="AlumnoId" class="form-select border-primary" asp-items="ViewBag.Alumnos" required>
                    <option value="">-- Seleccione Alumno (Matrícula y Nombre) --</option>
                </select>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Carrera a Cursar</label>
                <select asp-for="CarreraId" class="form-select border-primary" asp-items="ViewBag.Carreras" required>
                    <option value="">-- Seleccione Carrera --</option>
                </select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Periodo de Ingreso / Reinscripción</label>
                <select asp-for="PeriodoId" class="form-select border-primary" asp-items="ViewBag.Periodos" required>
                    <option value="">-- Seleccione Periodo --</option>
                </select>
            </div>
        </div>
        <div class="mt-4 text-end">
            <a asp-action="Index" class="btn btn-secondary me-2">Cancelar</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Procesar Inscripción</button>
        </div>
    </form>
</div>