@model List<universidad1.Models.Inscripcion>

@{
    ViewData["Title"] = "Inscripciones";
}

<div class="container mt-4">
    <h2>Control de Inscripciones</h2>
    <hr />

    <div class="mb-3 mt-3 text-end">
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-pencil-square"></i> Inscribir Alumno
        </a>
    </div>

    <table class="table table-striped table-hover shadow-sm align-middle">
        <thead class="table-dark">
            <tr>
                <th>Matrícula</th>
                <th class="text-info">Alumno</th>
                <th class="text-warning">Carrera</th>
                <th>Periodo</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr><td colspan="5" class="text-center">No hay alumnos inscritos.</td></tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary">@item.Matricula</span></td>
                        <td><strong>@item.NombreAlumno</strong></td>
                        <td>@item.NombreCarrera</td>
                        <td>@item.ClavePeriodo</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i> Modificar
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>