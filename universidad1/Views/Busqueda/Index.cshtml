@model universidad1.Models.BusquedaViewModel
@{
    ViewData["Title"] = "Localizador de Alumnos";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 15px;">
                <form method="get" asp-action="Index">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white border-end-0 text-primary"><i class="bi bi-search"></i></span>
                        <input type="text" name="q" class="form-control border-start-0"
                               placeholder="Buscar por nombre del alumno..." value="@Model.TerminoBusqueda">
                        <button class="btn btn-primary px-4" type="submit">Buscar</button>
                    </div>
                </form>
            </div>

            @if (Model.Resultados.Any())
            {
                <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 15px;">
                    <h6 class="fw-bold mb-3">Resultados encontrados</h6>
                    <div class="list-group list-group-flush">
                        @foreach (var a in Model.Resultados)
                        {
                            <a asp-action="RegistrarConsulta" asp-route-id="@a.Id"
                                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 border-0 border-bottom">
                                <div>
                                    <span class="d-block fw-bold text-dark">@a.Nombre</span>
                                    <small class="text-muted">@a.Carrera</small>
                                </div>
                                <i class="bi bi-chevron-right text-primary"></i>
                            </a>
                        }
                    </div>
                </div>
            }
            else if (!string.IsNullOrEmpty(Model.TerminoBusqueda))
            {
                <div class="card border-0 shadow-sm p-5 text-center mb-4" style="border-radius: 15px;">
                    <div class="mb-3">
                        <i class="bi bi-person-x fs-1 text-muted"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Alumno no encontrado</h5>
                    <p class="text-muted mb-0">
                        No pudimos encontrar a ningún alumno que coincida con "<strong class="text-primary">@Model.TerminoBusqueda</strong>".
                    </p>
                    <small class="text-muted mt-2 d-block">Intenta buscar por nombre o apellido paterno.</small>
                </div>
            }

            <div class="card border-0 shadow-sm p-4" style="border-radius: 15px; background: #fdfdfd;">
                <h6 class="text-muted fw-bold mb-3"><i class="bi bi-clock-history me-2"></i>Búsquedas Recientes</h6>
                <div class="row">
                    @foreach (var h in Model.HistorialReciente)
                    {
                        <div class="col-md-6 mb-2">
                            <div class="d-flex align-items-center p-2 border rounded bg-white shadow-sm">
                                <div class="bg-primary-subtle text-primary rounded-circle p-2 me-3">
                                    <i class="bi bi-person"></i>
                                </div>
                                <div class="overflow-hidden">
                                    <span class="d-block small fw-bold text-truncate text-dark">@h.Nombre</span>
                                    <span class="d-block text-muted" style="font-size: 0.7rem;">@h.Carrera</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>